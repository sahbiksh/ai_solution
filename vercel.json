{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "ai-solutions-api": {
      "type": "web",
      "root": "backend",
      "entrypoint": "src/server.js",
      "routePrefix": "/_/ai-solutions-api",
      "buildCommand": "npm install"
    },
    "ai-solutions-frontend": {
      "type": "web",
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    }
  }
}
